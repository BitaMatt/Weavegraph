{
  "name": "weavegraph",
  "version": "1.1.1",
  "description": "客户关系网络思维导图工具",
  "main": "main.js",
  "scripts": {
    "start": "chcp 65001 && electron .",
    "build": "electron-builder --win",
    "build:win": "powershell -command \"$env:BUILD_DATE = Get-Date -Format 'yyyy-MM-dd'; electron-builder --win\"",
    "build:mac": "electron-builder --mac",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "electron",
    "cytoscape",
    "mindmap",
    "visualization",
    "crm"
  ],
  "author": "曹振威（Tom Chou）",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cytoscape": "^3.29.0"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.weavegraph.app",
    "productName": "人脈織圖(WeaveGraph)",
    "electronVersion": "41.2.0",
    "icon": "icon/logo.png",
    "directories": {
      "output": "build",
      "buildResources": "build"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "package.json",
      "splash.html",
      "icon/**/*",
      "templates/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-win64.${ext}",
      "asar": true,
      "asarUnpack": [
        "templates/**/*"
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "${productName}-${version}-mac.${ext}",
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh",
      "shortcutName": "人脈織圖(WeaveGraph)",
      "installerLanguages": ["zh_CN", "zh_TW", "en_US", "ja_JP"],
      "language": "0804",
      "perMachine": false,
      "differentialPackage": false,
      "warningsAsErrors": false,
      "include": "build/installer.nsh"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
