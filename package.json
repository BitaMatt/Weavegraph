{
  "name": "mindmapinterface",
  "version": "1.0.3",
  "description": "客户关系网络思维导图工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --mac",
    "build:win": "powershell -command \"$env:BUILD_DATE = Get-Date -Format 'yyyy-MM-dd'; electron-builder --win\"",
    "build:mac": "electron-builder --mac",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "electron",
    "cytoscape",
    "mindmap",
    "visualization",
    "crm"
  ],
  "author": "曹振威",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cytoscape": "^3.29.0"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.mindmap.interface",
    "productName": "MindMapInterface",
    "electronVersion": "41.2.0",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/**/*",
      "!dist/**/*",
      "!\\.trae/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-win64.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "${productName}-${version}-mac.${ext}",
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MindMapInterface",
      "installerLanguages": ["zh_CN", "zh_TW", "en_US", "ja_JP"],
      "language": "0804",
      "perMachine": false,
      "differentialPackage": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
